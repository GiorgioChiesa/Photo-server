# Flask Configuration
SECRET_KEY=your-secret-key-at-least-32-characters-long

# Database (SQLite path)
DATABASE_URL=sqlite:///data/photos.db

# Upload folder (use external drive path if needed)
UPLOAD_FOLDER=./uploads

# Environment
FLASK_ENV=development

# Cloudflare Tunnel (optional, for remote access)
# Get token from: https://dash.cloudflare.com/:accountId/:zoneId/tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# ngrok (alternative to Cloudflare)
# Get token from: https://dashboard.ngrok.com/get-started/setup
NGROK_AUTH_TOKEN=